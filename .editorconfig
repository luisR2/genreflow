root = true
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,html,css,json}]
indent_size = 2
indent_style = space

[{Makefile,*.mk}]
indent_style = tab

[*.py]
indent_size = 4
indent_style = space

[{*.yaml,*.yml}]
indent_style = space
indent_size = 2

[*.sh]
indent_size = 4
indent_style = space

[Dockerfile]
indent_size = 4

[*.md]
trim_trailing_whitespace = false